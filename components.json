{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-nova",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/renderer/src/app.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@renderer/components",
    "utils": "@renderer/lib/utils",
    "ui": "@renderer/components/ui",
    "ai-elements": "@renderer/components/ai-elements",
    "lib": "@renderer/lib",
    "hooks": "@renderer/hooks"
  },
  "registries": {
    "@ai-elements": "https://ai-sdk.dev/elements/api/registry/{name}.json",
    "@svgl": "https://svgl.app/r/{name}.json"
  },
  "menuColor": "default",
  "menuAccent": "subtle"
}
